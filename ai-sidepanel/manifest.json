{
  "manifest_version": 3,
  "name": "Local AI Agent Side Panel",
  "version": "3.0",
  "description": "AI agent side panel with multimodal request support, local history, and OpenAI-compatible API calls",
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "action": {
    "default_title": "Open AI Agent Panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "settings.html",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["api-content-script.js"],
      "run_at": "document_end"
    }
  ]
}
